{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "type": "builtin",
        "source": "apple",
        "padding": {
            "top": 1,
            "left": 3
        }
    },
    "display": {
        "separator": " › ",
        "key": {
            "width": 16
        }
    },
    "modules": [
        "break",
        {
            "type": "title",
            "key": "  ",
            "format": "{user-name} @ {host-name}",
            "keyColor": "blue"
        },
        {
            "type": "custom",
            "format": "───────────────────────────────────────"
        },
        {
            "type": "os",
            "key": "  OS",
            "keyColor": "cyan"
        },
        {
            "type": "kernel",
            "key": "  Kernel",
            "keyColor": "cyan"
        },
        {
            "type": "uptime",
            "key": "  Uptime",
            "keyColor": "cyan"
        },
        {
            "type": "packages",
            "key": "  Packages",
            "keyColor": "cyan"
        },
        {
            "type": "shell",
            "key": "  Shell",
            "keyColor": "cyan"
        },
        {
            "type": "terminal",
            "key": "  Terminal",
            "keyColor": "cyan"
        },
        "break",
        {
            "type": "cpu",
            "key": "  CPU",
            "keyColor": "green"
        },
        {
            "type": "gpu",
            "key": "󰢮  GPU",
            "keyColor": "green"
        },
        {
            "type": "memory",
            "key": "  Memory",
            "keyColor": "yellow"
        },
        {
            "type": "disk",
            "key": "  Disk",
            "keyColor": "red"
        },
        "break",
        {
            "type": "localip",
            "key": "󰛴  Local IP",
            "keyColor": "magenta"
        },
        "break",
        {
            "type": "colors",
            "paddingLeft": 2,
            "symbol": "circle"
        }
    ]
}
