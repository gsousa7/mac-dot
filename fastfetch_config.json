{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "type": "none"
    },
    "display": {
        "separator": " › ",
        "key": {
            "width": 16
        }
    },
    "modules": [
        {
            "type": "title",
            "key": "  ",
            "format": "{user-name} @ {host-name}",
            "keyColor": "blue"
        },
        {
            "type": "custom",
            "format": "───────────────────────────────────────"
        },
        {
            "type": "uptime",
            "key": "  Uptime",
            "keyColor": "cyan"
        },
        {
            "type": "packages",
            "key": "  Packages",
            "keyColor": "cyan"
        },
        {
            "type": "memory",
            "key": "  Memory",
            "keyColor": "yellow"
        },
        {
            "type": "swap",
            "key": "  Swap",
            "keyColor": "green"
        },
        {
            "type": "disk",
            "key": "  Disk",
            "keyColor": "red"
        }
    ]
}
